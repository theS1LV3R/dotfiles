# Theming
export QT_QPA_PLATFORMTHEME=qt6ct

# Cursor
export XCURSOR_SIZE=20
export HYPRCURSOR_SIZE=20

# Scaling and whatnot
export GDK_SCALE=2 # Ensure X11 GTK applications are scaled correctly
export QT_AUTO_SCREEN_SCALE_FACTOR=1
